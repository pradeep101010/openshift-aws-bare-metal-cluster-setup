    "bastion_public_ip": {
      "value": "3.216.134.223",
      "type": "string"
    },
    "cluster_api_url": {
      "value": "https://api.ocp-poc.example.com:6443",
      "type": "string"
    },
    "cluster_console_url": {
      "value": "https://console-openshift-console.apps.ocp-poc.example.com",
      "type": "string"
    },
    "next_steps": {
      "value": "1. Wait ~10 min for bastion to finish setup:\n   ssh ubuntu@3.216.134.223 'tail -f /var/log/bastion-init.log'\n\n2. Once bastion shows 'BASTION READY', run the volume-swap script:\n   ./complete-setup.sh 3.216.134.223 us-east-1 ocp-poc\n\n3. Monitor bootstrap from bastion:\n   ssh ubuntu@3.216.134.223\n   openshift-install wait-for bootstrap-complete --dir=~/ocp-install --log-level=info\n\n4. After bootstrap completes, approve worker CSRs:\n   export KUBECONFIG=~/ocp-install/auth/kubeconfig\n   oc get csr | grep Pending | awk '{print $1}' | xargs oc adm certificate approve\n\n5. Monitor install completion:\n   openshift-install wait-for install-complete --dir=~/ocp-install --log-level=info\n",
      "type": "string"
    },
