# Instance types
bastion_instance_type = "t3.medium"   # Needs ~30 GB free for RHCOS image
node_instance_type    = "m5.metal"    # Must be bare metal

# Disk
rhcos_disk_size_gb = 130

# Networking
vpc_cidr    = "10.0.0.0/16"
subnet_cidr = "10.0.0.0/20"